# Core auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Trigger ingestion
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
INTERNAL_EVENTS_SECRET=
WEBHOOK_MAX_BODY_BYTES=262144
EXECUTION_WORKER_POLL_INTERVAL_MS=1000
EXECUTION_WORKER_HEARTBEAT_INTERVAL_MS=5000
EXECUTION_MAX_RETRIES=3
EXECUTION_RETRY_DELAYS_SECONDS=30,120,300
EXECUTION_WEBHOOK_TIMEOUT_MS=10000
OPERATIONS_QUEUE_BACKLOG_ALERT_THRESHOLD=50
OPERATIONS_STALE_RUN_ALERT_SECONDS=300
OPERATIONS_WEBHOOK_REJECTION_SPIKE_THRESHOLD=10
OPERATIONS_RETRY_EXHAUSTION_ALERT_THRESHOLD=5
OPERATIONS_ALERT_LOOKBACK_MINUTES=60
AUDIT_LOG_RETENTION_DAYS=365
EXECUTION_LOG_RETENTION_DAYS=90
INGESTION_EVENT_RETENTION_DAYS=30

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL="Nexus Orchestrator <onboarding@resend.dev>"

# Optional auth-specific secret overrides
MFA_EMAIL_CODE_SECRET=
MFA_ASSERTION_SECRET=
PASSKEY_ASSERTION_SECRET=

# Passkeys
PASSKEY_EXPECTED_ORIGIN=http://localhost:3000
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME="Nexus Orchestrator"

# Optional profile/avatar API
SUPABASE_AVATAR_BUCKET=avatars
