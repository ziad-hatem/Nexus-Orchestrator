# Core auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=
NEXT_PUBLIC_APP_URL=http://localhost:3000
LOG_LEVEL=info

# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Trigger ingestion
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
INTERNAL_EVENTS_SECRET=
WEBHOOK_SIGNATURE_TOLERANCE_SECONDS=300

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Email delivery
RESEND_API_KEY=
RESEND_FROM_EMAIL="Nexus Orchestrator <onboarding@resend.dev>"

# Optional auth-specific secret overrides
MFA_EMAIL_CODE_SECRET=
MFA_ASSERTION_SECRET=
PASSKEY_ASSERTION_SECRET=

# Passkeys
PASSKEY_EXPECTED_ORIGIN=http://localhost:3000
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME="Nexus Orchestrator"

# Optional profile/avatar API
SUPABASE_AVATAR_BUCKET=avatars
