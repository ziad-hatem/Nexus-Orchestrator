    "test:operations": "tsx --test tests/operations/*.test.ts",
    "test:phase-one": "tsx --test tests/phase-one/*.test.ts",
    "test:phase-two": "tsx --test tests/phase-two/*.test.ts",
    "test:phase-three": "tsx --test tests/phase-three/*.test.ts",
    "test:phase-four": "tsx --test tests/phase-four/*.test.ts",
    "test:phase-five": "tsx --test tests/phase-five/*.test.ts",
    "test:phase-six": "tsx --test tests/phase-six/*.test.ts",
    "test:phase-seven": "tsx --test tests/phase-seven/*.test.ts",
    "test:phase-eight": "tsx --test tests/phase-eight/*.test.ts",
