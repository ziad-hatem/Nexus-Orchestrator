  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "npm run test:security && npm run test:operations && npm run test:phase-one && npm run test:phase-two && npm run test:phase-three && npm run test:phase-four && npm run test:phase-five && npm run test:phase-six && npm run test:phase-seven && npm run test:phase-eight",
